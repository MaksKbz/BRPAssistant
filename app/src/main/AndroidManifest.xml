<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!--
        FOREGROUND_SERVICE_DATA_SYNC требуется для Android 14+ (API 34):
        WorkManager бросает MissingForegroundServiceTypeException если
        foregroundServiceType не объявлен в манифесте при запуске Expedited Worker.
        Соответствующий тип указан в ForegroundInfo внутри ModelDownloadWorker:
          ServiceInfo.FOREGROUND_SERVICE_TYPE_DATA_SYNC (только для Q+)
    -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <application
        android:name=".App"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.BRPAssistant"
        android:enableOnBackInvokedCallback="true"
        android:largeHeap="true"
        android:extractNativeLibs="true">

        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:theme="@style/Theme.BRPAssistant"
            android:resizeableActivity="true"
            android:windowSoftInputMode="adjustResize"
            android:configChanges="orientation|screenSize|smallestScreenSize|screenLayout|density">
            <!--
                resizeableActivity="true":
                  Явно разрешает multi-window и free-form режим.
                  Без этого на планшетах/фолдаблах система может запустить
                  приложение в compatibility window, игнорируя WindowSizeClass
                  и отключая адаптивную навигацию (NavigationRail).

                configChanges:
                  Объявляем, что Activity сама обрабатывает эти изменения конфигурации
                  вместо пересоздания. Compose + WindowSizeClass реагируют на них
                  автоматически через collectAsStateWithLifecycle, поэтому
                  пересоздание Activity не нужно и только замедляет UX.
            -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- HiltWorkerFactory: отключаем дефолтный WorkManagerInitializer,
             чтобы WorkManager инициализировался через App.workManagerConfiguration
             с HiltWorkerFactory — это требование для @HiltWorker-классов. -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

        <!--
            FIX: foregroundServiceType для WorkManager (Android 14+ / API 34).
            Без этой записи система бросает MissingForegroundServiceTypeException
            при запуске ModelDownloadWorker как Expedited Worker.
            Тип dataSync соответствует ServiceInfo.FOREGROUND_SERVICE_TYPE_DATA_SYNC
            который указан в getForegroundInfo() воркера.
        -->
        <service
            android:name="androidx.work.impl.foreground.SystemForegroundService"
            android:foregroundServiceType="dataSync"
            tools:node="merge" />

    </application>
</manifest>
