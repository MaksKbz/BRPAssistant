<?xml version="1.0" encoding="utf-8"?>
<!--
    Базовые размеры по умолчанию (телефоны).
    Планшетные/sw600dp переопределения — в values-sw600dp/dimens.xml.
    Эти объявления обязательны, иначе MissingDefaultResource при lintVitalRelease.
-->
<resources>
    <!-- Горизонтальные отступы контента -->
    <dimen name="screen_horizontal_padding">16dp</dimen>
    <dimen name="card_spacing">12dp</dimen>
    <dimen name="section_spacing">16dp</dimen>

    <!-- Максимальная ширина контента -->
    <dimen name="content_max_width">600dp</dimen>

    <!-- Размеры шрифтов по умолчанию -->
    <dimen name="text_size_body">14sp</dimen>
    <dimen name="text_size_label">12sp</dimen>
    <dimen name="text_size_caption">11sp</dimen>

    <!-- NavigationRail -->
    <dimen name="nav_rail_width">80dp</dimen>
</resources>
